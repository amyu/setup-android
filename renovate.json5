{
  extends: [
    'config:recommended',
    'customManagers:biomeVersions',
  ],
  timezone: 'Asia/Tokyo',
  minimumReleaseAge: '7 days',
  patch: {
    automerge: true,
  },
  packageRules: [
    {
      enabled: false,
      matchPackageNames: [
        '/@actions/cache/',
      ],
    },
    {
      groupName: 'Android Gradle Plugin',
      matchPackageNames: [
        'com.android.library{/,}**',
        'com.android.application{/,}**',
      ],
    },
  ],
}
